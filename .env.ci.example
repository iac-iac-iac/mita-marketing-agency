# =============================================================================
# DIRECT-LINE — Переменные окружения для CI/CD
# =============================================================================
# Скопируйте этот файл в .env.local и заполните значениями
# =============================================================================

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://direct-line.ru

# -----------------------------------------------------------------------------
# CRM Integration (Bitrix24)
# -----------------------------------------------------------------------------
BITRIX24_WEBHOOK_URL=https://your-company.bitrix24.ru/rest/1/your-webhook/
BITRIX24_CRM_ID=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_YANDEX_METRIKA_ID=XXXXXXXXX

# -----------------------------------------------------------------------------
# Email Notifications (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@direct-line.ru
EMAIL_TO=info@direct-line.ru

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
# -----------------------------------------------------------------------------
# Получить: https://sentry.io/settings/your-org/projects/
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx

# -----------------------------------------------------------------------------
# Vercel (для локального деплоя)
# -----------------------------------------------------------------------------
# Получить: https://vercel.com/account/tokens
# VERCEL_TOKEN=your-vercel-token
# VERCEL_ORG_ID=your-org-id
# VERCEL_PROJECT_ID=your-project-id

# =============================================================================
# ИНСТРУКЦИИ ПО НАСТРОЙКЕ CI/CD
# =============================================================================
#
# 1. GitHub Secrets:
#    - VERCEL_TOKEN
#    - VERCEL_ORG_ID
#    - VERCEL_PROJECT_ID
#
# 2. GitHub Variables:
#    - NEXT_PUBLIC_SITE_URL
#
# 3. Sentry:
#    - Создайте проект на https://sentry.io
#    - Скопируйте DSN в NEXT_PUBLIC_SENTRY_DSN
#
# 4. Bitrix24:
#    - Создайте webhook в Bitrix24
#    - Скопируйте URL в BITRIX24_WEBHOOK_URL
#
# =============================================================================
