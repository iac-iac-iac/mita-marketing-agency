{
  "name": "company_site",
  "version": "1.0.0",
  "description": "Direct-line — Маркетинговое IT-агентство полного цикла",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:staging": "next dev --port 3001",
    "build": "next build",
    "build:staging": "next build",
    "start": "next start",
    "start:staging": "next start --port 3001",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "analyze": "cross-env ANALYZE=true npm run build",
    "hash-password": "node scripts/hash-password.cjs",
    "test": "echo \"Tests coming soon\" && exit 0",
    "test:coverage": "echo \"Coverage coming soon\" && exit 0",
    "prepare": "node .husky/install.mjs",
    "precommit": "lint-staged"
  },
  "keywords": [
    "nextjs",
    "tailwindcss",
    "typescript",
    "direct-line"
  ],
  "author": "Direct-line",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.46.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.0.5",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "next": "^14.2.35",
    "next-mdx-remote": "^6.0.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  }
}
