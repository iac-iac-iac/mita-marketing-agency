# =============================================================================
# DIRECT-LINE — Staging окружение
# =============================================================================
# Этот файл содержит настройки для staging окружения.
# Используется для тестирования перед production.
# =============================================================================
#
# ОТЛИЧИЯ ОТ PRODUCTION:
# - Другой порт (3001 вместо 3000)
# - Отключена аналитика (или staging счётчики)
# - Тестовый Bitrix24 webhook (если есть)
#
# =============================================================================

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_SITE_NAME="Direct-line (Staging)"

# -----------------------------------------------------------------------------
# CRM Integration (Bitrix24)
# -----------------------------------------------------------------------------
# Используйте тестовый webhook для staging
BITRIX24_WEBHOOK_URL=
BITRIX24_CRM_ID=

# -----------------------------------------------------------------------------
# Analytics (отключено или staging счётчики)
# -----------------------------------------------------------------------------
# Для staging можно использовать отдельные тестовые счётчики
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YANDEX_METРИКА_ID=

# -----------------------------------------------------------------------------
# Email Notifications (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=staging@direct-line.ru
EMAIL_TO=staging@direct-line.ru

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_KEY=

# -----------------------------------------------------------------------------
# Chat Widget
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CHAT_WIDGET_ID=

# -----------------------------------------------------------------------------
# Image CDN
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# ИНСТРУКЦИИ ПО ЗАПУСКУ STAGING
# =============================================================================
#
# 1. Переименуйте этот файл в .env.local.staging
#    mv .env.local.staging.example .env.local.staging
#
# 2. Заполните необходимые переменные
#
# 3. Запустите staging сервер:
#    npm run dev:staging
#
# 4. Откройте http://localhost:3001
#
# =============================================================================
