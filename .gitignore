# =============================================================================
# Direct-line .gitignore
# =============================================================================
# Глобальные игноры для всего репозитория
# =============================================================================

# -----------------------------------------------------------------------------
# Зависимости
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
/out/
/build/
dist/

# Production
/next.config.js.*
!**/next.config.js

# -----------------------------------------------------------------------------
# Переменные окружения
# -----------------------------------------------------------------------------
.env*.local
.env*.staging
.env
!.env.example
!.env.local.example
!.env.local.staging.example
!.env.ci.example

# -----------------------------------------------------------------------------
# Логирование
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
logs/
*.log

# -----------------------------------------------------------------------------
# Тестирование
# -----------------------------------------------------------------------------
coverage/
test-results/
jest-results.xml
.playwright/
test-reports/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# IDE и редакторы
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.sublime-*

# -----------------------------------------------------------------------------
# Операционные системы
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Временные файлы
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.old
*.cache

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# Husky
# -----------------------------------------------------------------------------
.husky/*.db

# -----------------------------------------------------------------------------
# Storybook (если будет добавлен)
# -----------------------------------------------------------------------------
storybook-static/

# -----------------------------------------------------------------------------
# Sentry (если будет добавлен)
# -----------------------------------------------------------------------------
.sentryclirc

# -----------------------------------------------------------------------------
# Анализ бандла
# -----------------------------------------------------------------------------
.stats.json
*.analyze.html

# -----------------------------------------------------------------------------
# Лиды (development данные)
# -----------------------------------------------------------------------------
leads/

# -----------------------------------------------------------------------------
# Временные папки
# -----------------------------------------------------------------------------
temp/
tmp/
.cache/

# -----------------------------------------------------------------------------
# Документы разработки (не для production)
# -----------------------------------------------------------------------------
refactoring-ideas/
docs/plans/
docs/analysis_*.md
docs/promt.md
docs/MAGIC-UI*.md

# -----------------------------------------------------------------------------
# Изображения для разработки
# -----------------------------------------------------------------------------
images/OG_image/
images/background/
images/blog_category/
images/error/
images/hero-banner/
images/icons/icon_tool/
images/icons/security_icon/
images/icons/service_icon/
images/icons/stats_block/
images/process_steps/
images/team/

# -----------------------------------------------------------------------------
# Qwen Code (AI assistant)
# -----------------------------------------------------------------------------
.qwen/

# =============================================================================
# END OF FILE
# =============================================================================
