#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Commit-msg hook для проверки формата сообщений
# Требует Conventional Commits формат

echo "📝 Validating commit message format..."

# Читаем сообщение коммита
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Проверяем формат Conventional Commits
# Формат: type(scope): description или type: description
if ! echo "$COMMIT_MSG" | grep -qE "^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\([a-z0-9-]+\))?: .+"; then
  echo ""
  echo "❌ Invalid commit message format!"
  echo ""
  echo "Expected format: type(scope): description"
  echo ""
  echo "Examples:"
  echo "  feat: добавить новую форму обратной связи"
  echo "  fix(api): исправить ошибку валидации"
  echo "  docs: обновить README"
  echo "  refactor(components): упростить логику компонентов"
  echo ""
  echo "Available types:"
  echo "  feat     - новая функция"
  echo "  fix      - исправление ошибки"
  echo "  docs     - документация"
  echo "  style    - стиль кода (пробелы, точки с запятой)"
  echo "  refactor - рефакторинг без изменений функциональности"
  echo "  test     - добавление тестов"
  echo "  chore    - изменение конфигурации, зависимости"
  echo "  perf     - улучшение производительности"
  echo "  ci       - CI/CD конфигурация"
  echo "  build    - сборка, зависимости"
  echo "  revert   - откат коммита"
  echo ""
  exit 1
fi

echo "✅ Commit message format is valid"
