# =============================================================================
# М.И.Т.А. — Staging окружение
# =============================================================================
# Этот файл используется для staging/pre-production окружения.
# Скопируйте в .env.local для запуска staging версии локально.
# =============================================================================

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
# Staging URL (например, staging.М.И.Т.А.ru или Vercel preview)
NEXT_PUBLIC_SITE_URL=https://staging.М.И.Т.А.ru

# Название сайта с пометкой staging
NEXT_PUBLIC_SITE_NAME="М.И.Т.А. (Staging)"

# -----------------------------------------------------------------------------
# CRM Integration (Bitrix24)
# -----------------------------------------------------------------------------
# Staging webhook для тестирования интеграции
# Рекомендуется использовать тестовую воронку Bitrix24
BITRIX24_WEBHOOK_URL=

# ID тестовой воронки CRM
BITRIX24_CRM_ID=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
# Staging GA4 ID (отдельный поток данных для тестирования)
NEXT_PUBLIC_GA_ID=

# Staging Яндекс.Метрика (отдельный счётчик)
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# -----------------------------------------------------------------------------
# Email Notifications (SMTP)
# -----------------------------------------------------------------------------
# SMTP для staging (можно использовать test email сервисы)
SMTP_HOST=

SMTP_PORT=587

SMTP_USER=

SMTP_PASSWORD=

# Email с пометкой staging
EMAIL_FROM=noreply-staging@mita.ru

# Получатель тестовых заявок
EMAIL_TO=dev@mita.ru

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Staging API ключ (отличный от production)
NEXT_PUBLIC_API_KEY=

# -----------------------------------------------------------------------------
# Staging-specific flags
# -----------------------------------------------------------------------------
# Режим отладки (true для staging, false для production)
NEXT_PUBLIC_DEBUG=true

# Показывать watermark "Staging" на сайте
NEXT_PUBLIC_STAGING_WATERMARK=true

# =============================================================================
# END OF FILE
# =============================================================================
