# =============================================================================
# DIRECT-LINE — Шаблон переменных окружения
# =============================================================================
# Скопируйте этот файл в .env.local и заполните значения.
# Этот файл содержит описание всех доступных переменных окружения.
# =============================================================================
#
# ИНСТРУКЦИЯ ПО НАСТРОЙКЕ:
# 1. Скопируйте файл: cp .env.local.example .env.local
# 2. Заполните обязательные переменные (помечены 🔴)
# 3. Заполните опциональные переменные (помечены 🟢)
# 4. Запустите сервер: npm run dev
#
# =============================================================================

# -----------------------------------------------------------------------------
# 🔴 ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ
# -----------------------------------------------------------------------------

# URL сайта (production или development)
# Примеры: http://localhost:3000, https://direct-line.ru
# Обязательно для: генерации sitemap, metadata, canonical URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Bitrix24 webhook URL для интеграции с CRM
# Получить: https://your-company.bitrix24.ru/devops/
# Формат: https://your-company.bitrix24.ru/rest/1/your-webhook/
# Обязательно для: отправки заявок из форм
BITRIX24_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# 🟢 ОПЦИОНАЛЬНЫЕ ПЕРЕМЕННЫЕ
# -----------------------------------------------------------------------------

# ID воронки в Bitrix24 (необязательно)
# Найти в настройках CRM
# Если не указано, используется воронка по умолчанию
BITRIX24_CRM_ID=

# -----------------------------------------------------------------------------
# 🟢 АНАЛИТИКА (будут добавлены позже)
# -----------------------------------------------------------------------------

# Google Analytics 4 Measurement ID
# Получить: https://analytics.google.com/
# Формат: G-XXXXXXXXXX
# Пример: G-A1B2C3D4E5
NEXT_PUBLIC_GA_ID=

# Яндекс.Метрика Counter ID
# Получить: https://metrika.yandex.ru/
# Формат: XXXXXXXX (8 цифр)
# Пример: 12345678
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# -----------------------------------------------------------------------------
# 🟢 EMAIL УВЕДОМЛЕНИЯ (если есть SMTP доступ)
# -----------------------------------------------------------------------------

# SMTP сервер для отправки email
# Примеры: smtp.gmail.com, smtp.mail.ru, smtp.yandex.ru
SMTP_HOST=

# Порт SMTP сервера
# Обычно: 587 (TLS) или 465 (SSL)
SMTP_PORT=587

# Логин SMTP (email адрес)
SMTP_USER=

# Пароль SMTP (или app-specific password для Gmail)
SMTP_PASSWORD=

# Адрес отправителя (должен совпадать со SMTP_USER)
EMAIL_FROM=info@direct-line.ru

# Адрес получателя заявок (куда отправлять формы)
EMAIL_TO=leads@direct-line.ru

# -----------------------------------------------------------------------------
# 🟢 БЕЗОПАСНОСТЬ
# -----------------------------------------------------------------------------

# API ключ для защиты endpoints (опционально)
# Сгенерировать: openssl rand -hex 32
# Рекомендуется для production
NEXT_PUBLIC_API_KEY=

# -----------------------------------------------------------------------------
# 🟢 ОНЛАЙН-ЧАТ (будет добавлен позже)
# -----------------------------------------------------------------------------

# ID виджета чата (Tawk.to, Crisp, Intercom, etc.)
# Будет использоваться для интеграции онлайн-чата
NEXT_PUBLIC_CHAT_WIDGET_ID=

# -----------------------------------------------------------------------------
# 🟢 IMAGE CDN (будет добавлен позже)
# -----------------------------------------------------------------------------

# Cloudinary credentials для оптимизации изображений
# Получить: https://cloudinary.com/
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# 🟢 STAGING ОКРУЖЕНИЕ
# -----------------------------------------------------------------------------

# Для staging окружения используйте отдельный файл .env.local.staging
# Скопируйте этот файл и измените значения:
# cp .env.local.example .env.local.staging
#
# Отличия staging окружения:
# - NEXT_PUBLIC_SITE_URL=http://localhost:3001 (другой порт)
# - Другой Bitrix24 webhook (если есть staging CRM)
# - Отключена аналитика (или отдельный staging GA/Yandex)

# =============================================================================
# ИНСТРУКЦИИ ПО НАСТРОЙКЕ
# =============================================================================
#
# 1. БАЗОВАЯ НАСТРОЙКА (ОБЯЗАТЕЛЬНО):
#    cp .env.local.example .env.local
#    
#    Заполните в .env.local:
#    NEXT_PUBLIC_SITE_URL=http://localhost:3000
#    BITRIX24_WEBHOOK_URL=https://your-company.bitrix24.ru/rest/1/your-webhook/
#
# 2. ЗАПУСК СЕРВЕРА:
#    npm run dev
#
# 3. ПРОВЕРКА:
#    Откройте http://localhost:3000
#    Проверьте консоль на наличие ошибок валидации
#
# 4. STAGING ОКРУЖЕНИЕ:
#    cp .env.local.example .env.local.staging
#    Измените NEXT_PUBLIC_SITE_URL=http://localhost:3001
#    npm run dev:staging
#
# =============================================================================
