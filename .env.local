# =============================================================================
# DIRECT-LINE — Локальные переменные окружения
# =============================================================================

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
# Для доступа по IP укажите ваш локальный IP
# Узнать IP: ipconfig | findstr /i "IPv4"
NEXT_PUBLIC_SITE_URL=http://192.168.0.86:3000

# Название сайта для metadata и SEO
NEXT_PUBLIC_SITE_NAME="Direct-line"

# -----------------------------------------------------------------------------
# CRM Integration (Bitrix24)
# -----------------------------------------------------------------------------
BITRIX24_WEBHOOK_URL=
BITRIX24_CRM_ID=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YANDEX_METРИКА_ID=

# -----------------------------------------------------------------------------
# Email Notifications (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@direct-line.ru
EMAIL_TO=info@direct-line.ru

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_KEY=

# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# END OF FILE
# =============================================================================
